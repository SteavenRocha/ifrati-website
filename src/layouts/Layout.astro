---
import "@fontsource-variable/open-sans";

import Header from "../components/Header.astro";

interface Props {
	title: string;
}

const { title } = Astro.props; 
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* PROPIEDADES GENERALES */
		--primary-color: #f27051;
		--primary-50: #FEF2EF;
		--secondary-color: #1b2a41;
		--secondary-300: #819ECB;
		--secondary-700: #253A5A;
		--secondary-100: #c9d5e9;
		--color-white: #ffffff;
		--gray-1000: #1C1C1E;
		--gray-600: #636366;
		--gray-200: #E5E5EA;
		--gray-400: #C7C7CC;

		/* PROPIEDADES DE TEXTOS */
		--text-white: #ffffff;
		--text-black: #2c2c2e;
		--text-paragraph: #3A3A3C;
		--secondary-text-color: #1b2a41;;

		/* PROPIEDADES DEL BOTON */
		--color-button: #f27051;
		--text-button-color: #ffffff;
		--primary-color-hover: #F05631;

		/* PROPIEDADES DE LA PANTALLA */
		--max-width: 1300px;
		--max-height: 900px;
	}

	html,
	body,
	* {
		font-family: "Open Sans Variable", sans-serif;
		font-size: 16px;
		margin: 0;
		width: 100%;
		height: auto;
		box-sizing: border-box;
		text-decoration: none;
		scroll-behavior: smooth;
	}

	.primary-titulo {
		font-family: "Poppins", sans-serif;
		font-weight: 700;
        font-size: 2rem;
		color: var(--primary-color);
	}

	.primary-subtitulo {
		font-family: "Poppins", sans-serif;
		font-weight: 650;
        font-size: 1.5rem;
		color: var(--primary-color);
	}

	.primary-parrafo {
		color: var(--primary-color);
		font-weight: 700;
	}

	h1 {
		color: var(--secondary-color);
		font-family: "Poppins", sans-serif;
	}

	p {
        color: var(--text-paragraph);
	}
</style>
