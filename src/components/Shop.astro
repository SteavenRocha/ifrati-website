<style>
    section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        max-width: var(--max-width);
        height: auto;
        gap: 30px;
        padding: 50px 16px;
    }

    .container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 50px;
        height: 100%;
    }

    .slider__container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        /* overflow: hidden; */
    }

    .card__container {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: calc(100% - 225px);
        padding: 10px;
        gap: 20px;
        background-color: var(--color-white);
    }

    .card {
		overflow: hidden;
        width: 100%;
        height: 100%;
		min-height: 100%;
		border-radius: 10px;
		box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }
    
    .imagen img {
        object-fit: cover;
        width: 100%;
        height: 100%;
    }

    .imagen p {
        font-size: 0.7rem;
        position: absolute;
        top: 2%;
        right: 2%;
        width: auto;
        padding: 5px;
        border-radius: 10px;
        background-color: var(--green-550);
        color: var(--color-white);
    }

    .imagen {
        position: relative;
        height: 225px;
    }

    .detalles {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 15px;
        height: 100%;
    }

    .content__detalles {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .pildoras {
        display: flex;
        gap: 10px;
    }

    .pildoras p {
        font-size: 0.7rem;
        background-color: var(--primary-50);
        color: var(--primary-color);
        width: auto;
        padding: 5px;
        border-radius: 10px;
    }

    .descripcion {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .descripcion h3,
    .descripcion p {
        text-align: start;
    }

    .descripcion p {
        font-size: 0.9rem;
    }

    .descripcion h3 {
        font-size: 1.15rem;
    }

    .mas__detalles p,
    strong {
        text-align: start;
        font-size: 0.8rem;
    }

    .elaborado,
    .entrega {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .icon {
        width: 15px;
        color: var(--secondary-color);
    }

    .cta {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
    }

    .botones {
        display: flex;
        justify-content: center;
    }
</style>
