---
import Slider from "./ui/Slider.astro";
import Button from "./ui/Button.astro";
import Right from "../assets/icons/right-arrow.svg";
import Person from "../assets/icons/person.svg";
import Clock from "../assets/icons/clock.svg";
---

<section>
    <div class="container">
        <div class="textos">
            <h1>Tienda <span class="primary-titulo">Solidaria</span></h1>

            <p>
                También puedes comprar alguno de nuestros productos
                desarrollados por nuestros estudiantes. Cada compra contribuye
                directamente a la sostenibilidad de nuestro programa social.
            </p>
        </div>

        <div class="slider__container">
            <h2><span class="primary-subtitulo">Productos</span> destacados</h2>

            <Slider cant={10} cantShow={4} id="slider-shop">
                <div class="card__section">
                    <div class="card">
                        <div class="imagen">
                            <p>Mas vendido</p>
                            <img
                                src="/img/productos/producto-1.jpg"
                                alt="producto-1"
                            />
                        </div>
                        <div class="card__container">
                            <div class="detalles">
                                <div class="content__detalles">
                                    <div class="pildoras">
                                        <p>Orgánico</p>
                                        <p>Sin conservantes</p>
                                    </div>
                                    <div class="descripcion">
                                        <h3>Pan Artesanal Rústico</h3>
                                        <p>
                                            Elaborado con masa madre natural y
                                            harina orgánica de trigo integral.
                                            Fermentación lenta de 24 horas que
                                            aporta un sabor único y una corteza
                                            crujiente.
                                        </p>
                                    </div>
                                </div>

                                <div class="mas__detalles">
                                    <div class="elaborado">
                                        <Person class="icon" />
                                        <p>
                                            <strong
                                                >Elaborado por:
                                            </strong>Estudiantes de pastelería.
                                        </p>
                                    </div>
                                    <div class="entrega">
                                        <Clock class="icon" />
                                        <p>
                                            <strong>Entrega:</strong> 1-2 días (horneado
                                            bajo pedido)
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <Button
                                text="Ver detalles"
                                destino="/#"
                                icon={Right}
                                bgColor="var(--color-white)"
                                color="var(--secondary-color)"
                                border="1px solid var(--primary-color)"
                                hoverColor="var(--gray-100)"
                                fontSize=".9rem"
                            />
                        </div>
                    </div>
                </div>

                <div class="card__section">
                    <div class="card">
                        <div class="imagen">
                            <p>Nuevo</p>
                            <img
                                src="/img/productos/producto-2.jpg"
