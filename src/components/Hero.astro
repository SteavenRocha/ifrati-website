---
import "@fontsource/poppins/100.css";
import "@fontsource/poppins/200.css";
import "@fontsource/poppins/300.css";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";
import "@fontsource/poppins/800.css";
import "@fontsource/poppins/900.css";

import Button from "./ui/Button.astro";
import Heart from "../assets/icons/heart.svg";
import Down from "../assets/icons/down-arrow.svg";
---

<section>
    <div class="container">
        <div class="left">
            <span class="logo">IFRATI</span>
            <h1 class="frase">
                Cada pan que horneamos <span class="primary-titulo">Cambia </span>una vida
            </h1>
            <p class="descripcion">
                Cada pan que hacemos no solo alimenta el cuerpo, sino que
                también nutre los sueños y el futuro de jóvenes con ganas de
                aprender y crecer. En cada receta, ponemos dedicación, pasión y
                un propósito más grande: brindar oportunidades reales a quienes
                las necesitan.
            </p>
            <div class="botones">
                <Button text="Donar Ahora" destino="/#" icon={Heart} />
                <Button
                    text="Descubre Más"
                    destino="#about"
                    icon={Down}
                    color="var(--secondary-color)"
                    bgColor="var(--color-white)"
                    hoverColor="var(--color-white)"
                />
            </div>
        </div>
        <div class="right">
            <img src="" alt="" />
        </div>
    </div>
</section>

<style>
    section {
        display: flex;
        align-items: center;
        justify-content: center;
        max-width: var(--max-width);
        height: calc(100svh - 70px);
        max-height: var(--max-height);
        padding: 0 16px;
    }

    .container {
        padding: 5% 0;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
    }

    .left {
        width: 50%;
        display: flex;
        flex-direction: column;
        align-items: start;
        justify-content: center;
        gap: 10px;
    }

    h1 {
        line-height: 1;
        color: var(--secondary-color);
        text-transform: uppercase;
        font-weight: 900;
        font-size: 3rem;
    }

    h1 span {
        font-size: 3rem;
        line-height: 1;
        font-weight: 900;
    }

    p {
        align-items: start;
        color: var(--text-paragraph);
    }

    .botones {
        display: flex;
        width: auto;
    }

    .right {
        width: 50%;
        height: 100%;
        background-color: rgb(214, 213, 213);
        border-radius: 10px;
    }

    img {
        width: 100%;
        height: 100%;
    }
</style>
