<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const botones = document.querySelectorAll(".categorias button");
        const contenidos = document.querySelectorAll(".contenido-item");
        const preguntas = document.querySelectorAll(".pregunta__container");

        botones.forEach((btn) => {
            btn.addEventListener("click", () => {
                botones.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                contenidos.forEach((contenido) => {
                    contenido.style.display = "none";
                });

                preguntas.forEach((pregunta) => {
                    const respuesta = pregunta.querySelector(".respuesta");
                    if (respuesta) {
                        respuesta.classList.remove("open");

                        const preguntaRespuesta = pregunta.querySelector(
                            ".pregunta__respuesta",
                        );
                        if (preguntaRespuesta) {
                            preguntaRespuesta.style.gap = "0";
                        }
                    }
                });

                const targetId = btn.getAttribute("data-target");
                const targetContent = document.getElementById(targetId);
                if (targetContent) {
                    targetContent.style.display = "flex";

                    const primeraPregunta = targetContent.querySelector(
                        ".pregunta__container",
                    );
                    if (primeraPregunta) {
                        const primeraRespuesta =
                            primeraPregunta.querySelector(".respuesta");
                        if (primeraRespuesta) {
                            primeraRespuesta.classList.add("open");

                            const preguntaRespuesta =
                                primeraPregunta.querySelector(
                                    ".pregunta__respuesta",
                                );
                            if (preguntaRespuesta) {
                                preguntaRespuesta.style.gap = "10px";
                            }
                        }
                    }
                }
            });
        });

        botones[0]?.classList.add("active");
        if (contenidos.length > 0) {
            contenidos[0].style.display = "flex";
            const primeraPregunta = contenidos[0].querySelector(
                ".pregunta__container",
            );
            if (primeraPregunta) {
                const primeraRespuesta =
                    primeraPregunta.querySelector(".respuesta");
                if (primeraRespuesta) {
                    primeraRespuesta.classList.add("open");

                    const preguntaRespuesta = primeraPregunta.querySelector(
                        ".pregunta__respuesta",
                    );
                    if (preguntaRespuesta) {
                        preguntaRespuesta.style.gap = "10px";
                    }
                }
            }
        }

        preguntas.forEach((item) => {
            item.addEventListener("click", () => {
                const respuesta = item.querySelector(".respuesta");
                const preguntaRespuesta = item.querySelector(
                    ".pregunta__respuesta",
                );

                if (respuesta) {
                    respuesta.classList.toggle("open");

                    if (respuesta.classList.contains("open")) {
                        if (preguntaRespuesta) {
                            preguntaRespuesta.style.gap = "10px";
                        }
                    } else {
                        if (preguntaRespuesta) {
                            preguntaRespuesta.style.gap = "0";
                        }
                    }

                    document.querySelectorAll(".respuesta").forEach((res) => {
                        if (res !== respuesta) {
                            res.classList.remove("open");

                            const preguntaRespuestaOtros = res
                                .closest(".pregunta__container")
                                .querySelector(".pregunta__respuesta");
                            if (preguntaRespuestaOtros) {
                                preguntaRespuestaOtros.style.gap = "0";
                            }
                        }
                    });
                }
            });
        });
    });
</script>

