---
import Happy from "../assets/icons/happy.svg";
import Question from "../assets/icons/question.svg";
import Down from "../assets/icons/arrow-down-line.svg";
import DownArrow from "../assets/icons/down-arrow.svg";
import Button from "./ui/Button.astro";
---

<section>
    <div class="container">
        <div class="textos">
            <h1>
                <span class="primary-titulo">Preguntas</span> Frecuentes
            </h1>
            <p>
                Encuentra respuestas a las preguntas más comunes sobre nuestra
                panadería social, nuestros programas y cómo puedes involucrarte.
            </p>
        </div>

        <div class="faq">
            <div class="categorias">
                <div class="item">
                    <button class="active" data-target="sobre-nosotros"
                        >Sobre nosotros
                        <Happy style={"width: 20px;"} />
                    </button>
                </div>

                <div class="item">
                    <button data-target="nuestro-programa"
                        >Sobre nuestro programa
                        <Happy style={"width: 20px;"} />
                    </button>
                </div>

                <div class="item">
                    <button data-target="donaciones"
                        >Sobre las donaciones
                        <Happy style={"width: 20px;"} />
                    </button>
                </div>

                <div class="item">
                    <button data-target="productos"
                        >Sobre tus compras
                        <Happy style={"width: 20px;"} />
                    </button>
                </div>
            </div>

            <div class="contenido">
